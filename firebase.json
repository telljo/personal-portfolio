{
  "functions": {
    "source": "functions",
    "codebase": "portfolio"
  },
  "hosting": {
    "public": "dist/personal-portfolio/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": {
          "functionId": "sendContactEmail",
          "region": "asia-southeast2",
          "pinTag": true
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
